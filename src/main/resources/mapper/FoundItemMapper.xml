<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.lostfound.mapper.FoundItemMapper">

    <resultMap id="foundItemResultMap" type="com.campus.lostfound.vo.FoundItemVO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="finder_name" property="finderName"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="category" property="category"/>
        <result column="location" property="location"/>
        <result column="event_time" property="eventTime"/>
        <result column="contact_info" property="contactInfo"/>
        <result column="images" property="images"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectFoundItemList" resultMap="foundItemResultMap">
        SELECT f.*, u.real_name AS finder_name
        FROM found_item f
        LEFT JOIN user u ON f.user_id = u.id
        WHERE 1 = 1
        <if test="category != null and category != ''">
            AND f.category = #{category}
        </if>
        <if test="keyword != null and keyword != ''">
            AND (f.title LIKE CONCAT('%', #{keyword}, '%')
                 OR f.description LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        ORDER BY f.create_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="selectFoundItemById" resultMap="foundItemResultMap">
        SELECT f.*, u.real_name AS finder_name
        FROM found_item f
        LEFT JOIN user u ON f.user_id = u.id
        WHERE f.id = #{id}
    </select>

</mapper>
